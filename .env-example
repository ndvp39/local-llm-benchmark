# =============================================================================
# .env-example — placeholders only. Copy to `.env` (git-ignored) and fill in.
# Constitution §6.4: secrets MUST come from env, NEVER from source.
# ADR-011: Anthropic is the sole runtime third-party API provider.
# =============================================================================

# Hugging Face Hub token — REQUIRED only for gated / private models.
# Source: https://huggingface.co/settings/tokens
# Used by: services/model_acquirer.py (HF download) routed through ApiGatekeeper.
HF_TOKEN=

# Anthropic Messages API key — REQUIRED for backends/api_backend.py (M4).
# Source: https://console.anthropic.com/settings/keys
# Used by: economic-analysis path (the third-party-API side of the break-even).
ANTHROPIC_API_KEY=

# Hugging Face cache root — OPTIONAL. Set this if your home-drive (default
# `~/.cache/huggingface`) doesn't have enough free space for model downloads
# (Llama-3-8B fp16 ≈ 16 GB, Qwen2-7B ≈ 14 GB before quantization). Point it at
# a drive with ≥ 50 GB free. `huggingface_hub` reads this env var directly.
# If you set it, also mirror the path in `config/setup.json.hf.cache_dir`.
# Example: HF_HOME=D:/AI_agents_course/hf_cache
HF_HOME=
